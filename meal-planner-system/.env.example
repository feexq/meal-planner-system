# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=meal_planner_db
DB_USER=user
DB_PASSWORD=password
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Normalizer (Python AI service) ────────────────────────
NORMALIZER_URL=http://localhost:8000

# ── LLM API Keys (required for AI features) ──────────────
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=your-base64-encoded-jwt-secret

# ── Stripe (required for payments) ────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Nova Poshta (delivery API) ────────────────────────────
NOVA_API_KEY=your-nova-poshta-api-key

# ── Azure Blob Storage (avatar uploads) ───────────────────
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
IMAGE_CONTAINER_NAME=profile-images
RECIPE_CONTAINER_NAME=recipe-images
PRODUCT_CONTAINER_NAME=ingredients-images

# ── OAuth2 (Google login) ────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OAuth2 (GitHub login) ────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
